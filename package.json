    "@tanstack/react-table": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "@tanstack/start-static-server-functions": "^1.166.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.32.0",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
