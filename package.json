{
  "name": "cvault",
  "version": "0.1.0",
  "description": "Centralized Claude Code credential vault and sync system across machines",
  "author": "Saad Nauman <saadijutt007@gmail.com>",
  "license": "MIT",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "build": "cd frontend && vite build && cp dist/client/_shell.html dist/client/index.html",
    "preview": "cd frontend && vite preview",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:scenario": "vitest run --passWithNoTests --config vitest.scenario.config.ts",
    "test:integration": "vitest run --passWithNoTests --config vitest.integration.config.ts",
    "prepare": "husky",
    "shadcn:add": "npx shadcn@latest add",
    "setup:cloudflare": "tsx scripts/setupCloudflare.ts"
  },
  "volta": {
    "node": "22.21.1",
    "yarn": "4.12.0"
  },
  "dependencies": {
    "@clerk/backend": "^3.0.2",
